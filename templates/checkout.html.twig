  <script src="/assets/js/index.js"></script>

  <!-- Script d'interface pour synchroniser le clic des cartes de paiement avec leurs boutons radios masqués -->
<script>
window.USER_CHECKOUT = JSON.parse(`{{ {
    logged: app.user ? true : false,
    name: app.user ? (app.user.nom ~ ' ' ~ app.user.prenom) : '',
    phone: app.user ? app.user.telephone : '',
    address: app.user ? app.user.adresse : ''
} | json_encode | e('js') }}`);
window.CHECKOUT_CSRF_TOKEN = "{{ csrf_token('checkout') }}";

  document.addEventListener('DOMContentLoaded', function() {
      const paymentCards = document.querySelectorAll('.payment-option-card');

      // Fonction unique pour synchroniser l'état visuel des cartes
      function updateCardStyles() {
          paymentCards.forEach(card => {
              const radio = card.querySelector('.payment-radio');
              if (radio && radio.disabled) {
                  card.style.setProperty('border-color', '#dee2e6', 'important');
                  card.style.backgroundColor = '#f8f8f8';
                  card.style.boxShadow = 'none';
                  return;
              }
              if (radio && radio.checked) {
                  // Style quand l'option est sélectionnée (Bordure colorée et fond légèrement teinté)
                  card.style.setProperty('border-color', '#D97C8A', 'important');
                  card.style.backgroundColor = 'rgba(239, 183, 193, 0.16)';
                  card.style.boxShadow = '0 4px 12px rgba(217, 124, 138, 0.16)';
              } else {
                  // Style par défaut quand l'option n'est pas sélectionnée
                  card.style.setProperty('border-color', '#dee2e6', 'important');
                  card.style.backgroundColor = '#fafafa';
                  card.style.boxShadow = 'none';
              }
          });
      }

      // 1. Écouter tous les changements d'état des boutons radio (gère le clic ET les modifs JS)
      document.querySelectorAll('.payment-radio').forEach(radio => {
          radio.addEventListener('change', updateCardStyles);
      });

      // 2. Permettre le clic n'importe où sur la carte pour cocher le radio correspondant
      paymentCards.forEach(card => {
          card.addEventListener('click', function(e) {
              const radio = this.querySelector('.payment-radio');
              if (radio && radio.disabled) {
                  return;
              }
              // Évite de provoquer une double activation si on a cliqué directement sur le bouton radio
              if (radio && e.target !== radio) {
                  radio.checked = true;
                  // Déclenche l'événement 'change' pour avertir vos autres scripts JS (comme index.js)
                  radio.dispatchEvent(new Event('change', { bubbles: true }));
              }
          });
      });

      // 3. Initialisation au chargement initial (pour l'option cochée par défaut "À la livraison")
      updateCardStyles();

      // Autonomie : Vérification périodique si votre script index.js manipule les propriétés sans déclencher d'événements
      setInterval(updateCardStyles, 300);
  });
</script>
</body>
