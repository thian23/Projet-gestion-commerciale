<body class="shop-page">


  <!--==============================
    Breadcrumb
============================== -->
<div class="breadcumb-wrapper position-relative" data-bg-src="assets/img/hero/bookstrore.avif" 
     style="padding: 120px 0; background-size: cover; background-position: center;">
  
  <div class="position-absolute top-0 start-0 w-100 h-100" style="background: rgba(0, 0, 0, 0.4);"></div>

  <div class="container position-relative z-3">
    <div class="breadcumb-content text-center">

      <h1 class="breadcumb-title text-white fw-bold mb-3 shadow-sm" style="font-size: 3.5rem; text-shadow: 2px 2px 10px rgba(0,0,0,0.5);">
        {{ shopTitle|default('Catalogue') }}
      </h1>


    </div>
  </div>
</div>

<section class="shop-catalog-section py-5 mb-5 mb-lg-0">
    <div class="container">

        <div class="row g-4">

            <!-- =========================
                 SIDEBAR (RESPONSIVE CLEAN)
            ========================== -->
            <div class="col-12 col-lg-4 col-xl-3 order-2 order-lg-1">

                <aside class="shop-sidebar">

                    <!-- 🔎 SEARCH -->
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-body">

                            <h6 class="fw-bold mb-3">Trouver un article</h6>

                            <form method="get" action="{{ path('app_shop') }}">
                                <div class="input-group">

                                    <input type="text"
                                           id="smartProductSearch"
                                           name="q"
                                           value="{{ currentSearch }}"
                                           class="form-control bg-light border-0"
                                           placeholder="Rechercher...">

                                    <input type="hidden" name="cat" value="{{ currentCategory }}">
                                    <input type="hidden" name="section" value="{{ currentSection }}">
                                    <input type="hidden" name="category_name" value="{{ currentCategoryName }}">

                                    <button class="btn" style="color: #10B981;" type="submit">
                                        <i class="fa fa-search"></i>
                                    </button>

                                </div>
                            </form>

                        </div>
                    </div>

                    <!-- 📌 FILTRES (ACCORDEON MOBILE) -->
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-body">

                            <button class="btn w-100 text-start fw-bold d-flex justify-content-between align-items-center"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#filterSection">
                                Filtres
                                <i class="fa fa-chevron-down"></i>
                            </button>

                            <div class="collapse show mt-3" id="filterSection">

                                <ul class="list-group list-group-flush">

                                    <li class="list-group-item border-0 px-0">
                                        <a href="{{ path('app_shop', { q: currentSearch }) }}"
                                           class="text-decoration-none d-block {{ currentSection is empty ? 'fw-bold active-filter' : 'text-dark' }}" style="color: #10B981;">
                                            Tous les produits
                                        </a>
                                    </li>

                                    <li class="list-group-item border-0 px-0">
                                        <a href="{{ path('app_shop', { section: 'phares', q: currentSearch }) }}"
                                           class="text-decoration-none d-block {{ currentSection == 'phares' ? 'fw-bold active-filter' : 'text-dark' }}" style="color: #10B981;">
                                            Produits phares
                                        </a>
                                    </li>

                                    <li class="list-group-item border-0 px-0">
                                        <a href="{{ path('app_shop', { section: 'promotions', q: currentSearch }) }}"
                                           class="text-decoration-none d-block {{ currentSection == 'promotions' ? 'fw-bold active-filter' : 'text-dark' }}" style="color: #10B981;">
                                            Promotions
                                        </a>
                                    </li>

                                    <li class="list-group-item border-0 px-0">
                                        <a href="{{ path('app_shop', { section: 'nouveautes', q: currentSearch }) }}"
                                           class="text-decoration-none d-block {{ currentSection == 'nouveautes' ? 'fw-bold active-filter' : 'text-dark' }}" style="color: #10B981;">
                                            Nouveautes
                                        </a>
                                    </li>

                                    <li class="list-group-item border-0 px-0">
                                        <a href="{{ path('app_shop', { section: 'best_sellers', q: currentSearch }) }}"
                                           class="text-decoration-none d-block {{ currentSection == 'best_sellers' ? 'fw-bold active-filter' : 'text-dark' }}" style="color: #10B981;">
                                            Best sellers
                                        </a>
                                    </li>

                                </ul>

                            </div>
                        </div>
                    </div>

                    <!-- 📂 CATEGORIES -->
                    <div class="card border-0 shadow-sm">

                        <div class="card-body">

                            <button class="btn w-100 text-start fw-bold d-flex justify-content-between align-items-center"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#catSection">
                                Rayons
                                <i class="fa fa-chevron-down"></i>
                            </button>

                            <div class="collapse show mt-3" id="catSection">

                                <ul class="list-group list-group-flush">

                                    {% for cat in categories %}
                                        <li class="list-group-item border-0 px-0">
                                            <a href="{{ path('app_shop', { cat: cat.id, q: currentSearch }) }}"
                                               class="text-decoration-none d-block {{ currentCategory == cat.id ? 'fw-bold active-filter' : 'text-dark' }}" style="color: #10B981;">
                                                {{ cat.nom }}
                                            </a>
                                        </li>
                                    {% endfor %}

                                </ul>

                            </div>

                        </div>
                    </div>

                </aside>
            </div>

            <!-- =========================
                 CONTENT (PRODUCTS)
            ========================== -->
            <div class="col-12 col-lg-8 col-xl-9 order-1 order-lg-2">

                <!-- HEADER -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="fw-semibold">
                        <span id="shopResultCount">{{ products|length }}</span>
                        produit{{ products|length > 1 ? 's' : '' }}
                    </span>
                </div>

                <!-- PRODUCTS -->
                <div class="row g-4" id="product-list">

                    {% for product in products %}
                        {% include 'components/product_card.html.twig' with { product: product } %}
                    {% endfor %}

                </div>

                <!-- EMPTY -->
                <div id="emptyShopResults" class="text-center py-5 d-none">
                    <i class="fa fa-search fa-2x mb-3"></i>
                    <h6>Aucun produit trouve</h6>
                    <p class="text-muted">Essayez un autre filtre</p>
                </div>

                <!-- PAGINATION -->
                <div class="d-flex justify-content-center mt-4">
                    <ul class="pagination gap-2" id="pagination"></ul>
                </div>

            </div>

        </div>
    </div>
</section>

{{ include('footer.html.twig') }}

