<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>
    SenBazar - Marketplace au Senegal | Produits, boutiques & promotions
  </title>

  <meta name="description" content="SenBazar est une marketplace senegalaise pour acheter des produits locaux, decouvrir des boutiques et profiter de promotions avec une livraison rapide.">
  
  <meta name="keywords" content="SenBazar, marketplace Senegal, boutique en ligne Dakar, produits locaux, promotions Senegal">

  <meta name="robots" content="index, follow">

  <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">

  <!-- Open Graph -->
  <meta property="og:title" content="SenBazar - Marketplace au Senegal">
  <meta property="og:description" content="Produits, boutiques et promotions au Senegal.">
  <meta property="og:image" content="{{ asset('assets/img/brand/logoN.jpeg') }}">
  <meta property="og:url" content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
  <meta property="og:type" content="website">

  <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
  <!-- Fontawesome Icon -->
  <link rel="stylesheet" href="/assets/css/fontawesome.min.css">
  <!-- Magnific Popup -->
  <link rel="stylesheet" href="/assets/css/magnific-popup.min.css">
  <!-- Slick Slider -->
  <link rel="stylesheet" href="/assets/css/slick.min.css">
  <!-- nice-select -->
  <link rel="stylesheet" href="/assets/css/nice-select.min.css">
  <!-- animate js -->
  <link rel="stylesheet" href="/assets/css/animate.min.css">
  <!-- nouislider js -->
  <link rel="stylesheet" href="/assets/css/nouislider.css">
  <!-- Theme Custom CSS -->
  <link rel="stylesheet" href="/assets/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
  <!-- Favicon -->
  <link rel="icon" href="/assets/img/brand/logoN.jpeg">
  <!-- Fonts & CSS -->
  <link rel="preconnect" href="https://fonts.googleapis.com">

</head>
<body>

  <!-- Preloader -->
  <div class="preloader">
    <button class="vs-btn preloaderCls">Annuler le chargement</button>
    <div class="preloader-inner">
      <img src="/assets/img/brand/logoN.jpeg" alt="SenBazar marketplace Senegal" class="deen-header-logo">
      <span class="loader"></span>
    </div>
  </div>

  <!-- Back to top -->
  <button class="back-to-top" id="backToTop" aria-label="Retour en haut">
    <span class="progress-circle">
      <svg viewBox="0 0 100 100">
          <circle class="bg" cx="50" cy="50" r="40"></circle>
          <circle class="progress" cx="50" cy="50" r="40"></circle>
      </svg>
      <span class="progress-percentage" id="progressPercentage">0%</span>
    </span>
  </button>

  <!-- Mobile Menu Wrapper -->
  <div class="vs-menu-wrapper">
    <div class="vs-menu-area text-center py-4">
      <!-- LOGO MOBILE -->
      <div class="mobile-logo d-flex align-items-center justify-content-between px-3 mb-4">
        <a href="{{ path('app_home') }}">
          <img src="/assets/img/brand/logoN.jpeg" alt="ebukz" class="logo img-fluid rounded-3" style="max-height:80px; width:auto; border: 1px solid rgba(0,0,0,0.05);">
        </a>
        <button class="vs-menu-toggle rounded-circle border-0 d-flex align-items-center justify-content-center bg-light text-dark" style="width: 40px; height: 40px;"><i class="fal fa-times"></i></button>
      </div>

      <div class="vs-mobile-menu text-start px-3">
        <ul class="list-unstyled">
          <li class="py-2 border-bottom"><a href="{{ path('app_home') }}" class="text-dark text-decoration-none fw-medium d-block">Accueil</a></li>
          <li class="py-2 border-bottom"><a href="{{ path('app_shop') }}" class="text-dark text-decoration-none fw-medium d-block">Boutique</a></li>
          <li class="menu-item-has-children py-2 border-bottom">
            <a href="#" class="text-dark text-decoration-none fw-medium d-block">Categories</a>
            <ul class="sub-menu list-unstyled ps-3 pt-2 small bg-light rounded-3 mt-2" style="display: none;">
               {% for category in categories %}
                  <li class="py-1.5">
                    <a href="{{ path('app_shop', { 'cat': category.id }) }}" class="dropdown-item category-link text-secondary" data-id="{{ category.id }}">
                      {{ category.nom }}
                    </a>
                  </li>
               {% endfor %}
            </ul>
          </li>
        </ul>

        <div class="deen-mobile-actions rounded-4 bg-light p-3 mt-4 border-0">
          <a href="#" class="deen-mobile-action-item text-dark text-decoration-none small d-flex align-items-center mb-3">
            <i class="fal fa-location-arrow me-2 text-secondary"></i>
            <span>Dakar</span>
          </a>

          {% if app.user %}
            <a href="{{ path('profile') }}" class="btn btn-white w-100 shadow-sm border rounded-3 mb-2 small text-start py-2">
              <i class="fa-solid fa-user me-2 text-muted"></i> Mon profil
            </a>
            <a href="{{ path('logout') }}" class="btn btn-danger-soft text-danger w-100 rounded-3 small text-start py-2">
              <i class="fa-solid fa-right-from-bracket me-2"></i> Deconnexion
            </a>
          {% else %}
            <a href="#" class="btn btn-dark w-100 rounded-3 py-2 small" data-bs-toggle="modal" data-bs-target="#authModal">
              <i class="fa-solid fa-user me-2"></i> Connexion / S'inscrire
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <!-- Popup Search Box Desktop (Si activee par clic ailleurs) -->
  <div class="popup-search-box d-none d-lg-block">
    <button class="searchClose"><i class="fal fa-times"></i></button>
    <form action="{{ path('app_shop') }}" method="GET">
        <input type="text" name="q" class="border-theme rounded-pill" placeholder="Que recherchez-vous ?">
        <button type="submit"><i class="fal fa-search"></i></button>
    </form>
  </div>

  <!-- HEADER NAVBAR -->
  <header class="deen-navbar fixed-top border-bottom bg-white shadow-sm">

    <!-- 1. TOP BAR -->
    <div class="deen-topbar py-2 d-none d-md-block" style="background-color: var(--theme-color);">
      <div class="container">
        <div class="row align-items-center justify-content-between">
          <div class="col-auto">
            <div class="deen-topbar-info text-white small opacity-90 d-flex align-items-center gap-3">
              <span><i class="fa-solid fa-truck-fast me-1.5"></i> Livraison la plus rapide dans votre ville</span>
              <span class="opacity-50">|</span>
              <a href="mailto:contact@senbazar.sn" class="text-white text-decoration-none"><i class="fas fa-envelope me-1.5"></i> contact@senbazar.sn</a>
            </div>
          </div>
          <div class="col-auto">
            <div class="deen-topbar-actions d-flex align-items-center text-white small gap-3">
              <a class="text-white text-decoration-none opacity-90"><i class="fal fa-location-arrow me-1"></i> Dakar</a>
              {% if app.user %}
                <div class="user-dropdown">
                  <a href="#" class="user-toggle text-white">
                    <i class="fa-solid fa-user me-1"></i>
                    {{ app.user.nom }} {{ app.user.prenom }}
                    <i class="fa-solid fa-chevron-down ms-2 small"></i>
                  </a>

                  <ul class="user-menu">
                    <li><a href="{{ path('profile') }}">Mon profil</a></li>
                    <li><a href="{{ path('logout') }}" class="text-danger">Deconnexion</a></li>
                  </ul>
                </div>
              {% else %}
                <a href="#" class="text-white text-decoration-none fw-medium" data-bs-toggle="modal" data-bs-target="#authModal">
                  <i class="fa-solid fa-user-circle"></i> Connexion
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. MAIN HEADER -->
    <div class="deen-main-header py-2.5 bg-white">
      <div class="container">
        <div class="row align-items-center justify-content-between flex-nowrap">
          
          <!-- LOGO -->
          <div class="col-auto">
            <a href="{{ path('app_home') }}" class="d-block transition-all hover-scale">
              <img src="/assets/img/brand/logoN.jpeg" alt="Logo SenBazar" class="deen-header-logo img-fluid rounded-2" style="max-height: 75px; width: auto; height: auto;">
            </a>
          </div>

          <!-- BARRE DE RECHERCHE CORRIGEE (Desktop) -->
          <div class="col d-none d-lg-block px-5">
            <form action="{{ path('app_shop') }}" method="GET">
              <div class="input-group border rounded-pill bg-light border-light-subtle custom-search-group">
                
                <!-- Conteneur Dropdown Dedie -->
<div class="dropdown position-relative">
    <button
        type="button"
        id="desktopCategoryDropdown"
        class="btn btn-white border-0 px-3 small text-dark fw-medium h-100 d-flex align-items-center"
        style="background:#fff; border-radius:50px 0 0 50px; border-right:1px solid #eee !important;"
    >
        Categories
        <i class="fal fa-chevron-down ms-2"></i>
    </button>

    <ul
        id="desktopCategoryMenu"
        class="custom-dropdown-menu list-unstyled m-0"
    >
        {% if categories is defined and categories|length > 0 %}
            {% for category in categories %}
                <li>
                    <a
                        href="{{ path('app_shop', {'cat': category.id}) }}"
                        class="dropdown-item category-link py-2 px-3 small"
                    >
                        {{ category.nom }}
                    </a>
                </li>
            {% endfor %}
        {% else %}
            <li>
                <span class="dropdown-item-text text-muted small px-3 py-2 d-block">
                    Aucune categorie disponible
                </span>
            </li>
        {% endif %}
    </ul>
</div>

                <input type="text" name="q" value="{{ currentSearch ?? '' }}" class="form-control border-0 shadow-none bg-transparent ps-3 small text-dark" placeholder="Rechercher un produit, une boutique, une categorie...">

                <button class="btn border-0 px-4 transition-all d-flex align-items-center justify-content-center" style="background-color: #F59E0B; color: white; border-radius: 0 50px 50px 0;" type="submit">
                  <i class="fa-solid fa-magnifying-glass fs-6"></i>
                </button>
              </div>
            </form>
          </div>

          <!-- BOUTONS D'ACTIONS -->
          <div class="col-auto">
            <div class="d-flex align-items-center gap-2.5 gap-md-3">
              
              <!-- Wishlist -->
              <a href="{{ path('app_wishlist_index') }}" class="deen-action-btn btn rounded-circle position-relative d-flex align-items-center justify-content-center border-0 p-0" style="width: 44px; height: 44px; background-color: #f7f7f7; color: #444;">
                <i class="fal fa-heart fs-5"></i>
                <span class="wishlist-count position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark py-1 px-1.5" style="font-size: 10px;">0</span>
              </a>

              <!-- Cart (Panier) -->
              <a href="{{ path('app_cart_index') }}" class="deen-action-btn btn rounded-circle position-relative d-flex align-items-center justify-content-center border-0 p-0 shadow-sm text-white" style="width: 44px; height: 44px; background-color: #F59E0B;">
                <i class="fa-solid fa-basket-shopping fs-5"></i>
                <span class="cart-count position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark py-1 px-1.5" style="font-size: 10px;">0</span>
              </a>

              <!-- Numero d'assistance (Desktop) -->
              <div class="d-none d-md-flex align-items-center gap-2.5 ps-3 border-start border-light-subtle">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 44px; height: 44px; background-color: rgba(16, 185, 129, 0.1); color: #10B981 !important;">
                  <i class="fas fa-phone-alt" style="color: #F59E0B;"></i>
                </div>
                <div class="lh-sm">
                  <small class="text-muted d-block opacity-75" style="font-size: 10px;">Assistance 24h/7</small>
                  <strong class="small fw-bold text-dark" style="font-size: 13px;">(+221) 77 818 12 59</strong>
                </div>
              </div>

              <!-- Hamburger Menu Mobile Toggle -->
              <button class="btn btn-light rounded-circle d-lg-none p-0 d-flex align-items-center justify-content-center vs-menu-toggle" style="width: 42px; height: 42px; background: #f7f7f7; border: 0;">
                <i class="fal fa-bars text-dark fs-5"></i>
              </button>

            </div>
          </div>

        </div>
      </div>
    </div>
  </header>

  <!--==============================
    Styles Unifies & Ergonomie Complete
  ============================== -->
<style>
  html, body {
      margin: 0 !important;
      font-family: 'Poppins', sans-serif;
  }
  body {
      padding-top: 135px !important;
      background-color: #F9FAFB;
  }

  /* Barre de navigation principale */
  .deen-navbar {
      border-color: rgba(0, 0, 0, 0.04) !important;
      transition: all 0.3s ease-in-out;
  }
  
  /* Conteneur principal */
.custom-search-group {
    position: relative;
    overflow: visible !important;
}

/* Dropdown */
.custom-search-group .dropdown {
    position: relative !important;
}

/* Menu categories */
.custom-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 260px;
    max-height: 380px;
    overflow-y: auto;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 12px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.12);
    z-index: 999999;
    padding: 8px 0;
}


/* Affichage */
.custom-dropdown-menu.show {
    display: block;
}

/* Items */
.custom-dropdown-menu .dropdown-item {
    color: #333;
    text-decoration: none;
    display: block;
    transition: all 0.2s ease;
}

.custom-dropdown-menu .dropdown-item:hover {
    background-color: #f8f9fa;
    color: #10B981;
    padding-left: 20px;
}

/* Empecher les parents de couper le menu */
.deen-navbar,
.deen-main-header,
.container,
.row,
.col,
.input-group {
    overflow: visible !important;
}
  /* Actions (Hover des cercles) */
  .deen-action-btn {
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .deen-action-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(0,0,0,0.08) !important;
  }

  /* Menu Mobile Zone Recurrente */
  .vs-menu-area {
      background: #ffffff !important;
      box-shadow: 5px 0 30px rgba(0,0,0,0.1);
      transition: all 0.4s ease;
  }
  .vs-mobile-menu ul li a {
      padding: 10px 0;
      transition: color 0.2s ease;
  }
  .vs-mobile-menu ul li a:hover {
      color: #10B981 !important;
  }
  .btn-danger-soft {
      background-color: rgba(220, 53, 69, 0.08);
      border: none;
  }
  .btn-danger-soft:hover {
      background-color: rgba(220, 53, 69, 0.15);
  }

  /* Effets et Utilitaires */
  .transition-all { transition: all 0.2s ease-in-out; }
  .hover-scale:hover { transform: scale(1.02); }
  .hover-opacity-100:hover { opacity: 1 !important; }
  .shadow-xs { box-shadow: 0 2px 5px rgba(0,0,0,0.02); }

  /* Animations Dropdown Bootstrap */
  .animate-fade-in {
      animation: navFadeIn 0.2s ease-out;
  }
  @keyframes navFadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
  }

  /* Rendu d'adaptation Tablettes & Mobiles */
  @media (max-width: 991.98px) {
      body {
          padding-top: 85px !important;
      }
      .deen-main-header {
          padding-top: 6px !important;
          padding-bottom: 6px !important;
      }
      .deen-header-logo {
          max-height: 52px !important;
      }
  }
  @media (max-width: 575.98px) {
      body {
          padding-top: 74px !important;
      }
      .deen-header-logo {
          max-height: 45px !important;
      }
  }
  .user-dropdown {
  position: relative;
  display: inline-block;
}

.user-menu {
  display: none;
  position: absolute;
  right: 0;
  top: calc(100% + 10px);
  background: #fff;
  min-width: 180px;
  border-radius: 10px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  padding: 8px 0;
  z-index: 9999;
}

.user-menu.show {
  display: block;
}

.user-menu a {
  display: block;
  padding: 8px 15px;
  color: #333;
  text-decoration: none;
}

.user-menu a:hover {
  background: #f5f5f5;
}
  </style>

  <!-- JavaScript CDN Scripts -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> 
  <script src="/assets/js/index.js"></script>

  <!-- Traitement Dynamique d'affichage interactif Twig -->
  <script>
      {% if app.user %}
          window.USER_LOGGED_IN = true;
      {% else %}
          window.USER_LOGGED_IN = false;
      {% endif %}

      document.addEventListener("DOMContentLoaded", function () {

    const dropdown = document.querySelector(".dropdown");
    const toggle = document.querySelector(".dropdown-toggle");

    if (!dropdown || !toggle) return;

    // toggle manuel propre (optionnel)
    toggle.addEventListener("click", function (e) {
        e.stopPropagation();
    });

    // fermer si clic exterieur
    document.addEventListener("click", function () {
        const menu = dropdown.querySelector(".dropdown-menu");
        if (menu) menu.classList.remove("show");
    });

});

        document.addEventListener('DOMContentLoaded', function () {
          {% if app.flashes('login_error') is not empty %}
              let authModal = new bootstrap.Modal(document.getElementById('authModal'));
              authModal.show();
          {% endif %}
          
          // Gerer le toggle du sous-menu categories sur Mobile
          const catToggle = document.querySelector('.menu-item-has-children > a');
          if (catToggle) {
              catToggle.addEventListener('click', function(e) {
                  e.preventDefault();
                  const subMenu = this.nextElementSibling;
                  if (subMenu) {
                      $(subMenu).slideToggle(200);
                  }
              });
          }
        });
        // Dropdown Categories Desktop
const categoryButton = document.getElementById('desktopCategoryDropdown');
const categoryMenu = document.getElementById('desktopCategoryMenu');

if (categoryButton && categoryMenu) {

    // Ouvrir / fermer
    categoryButton.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        categoryMenu.classList.toggle('show');
    });

    // Empecher fermeture si clic dans le menu
    categoryMenu.addEventListener('click', function (e) {
        e.stopPropagation();
    });

    // Fermer si clic en dehors
    document.addEventListener('click', function (e) {
        if (
            !categoryButton.contains(e.target) &&
            !categoryMenu.contains(e.target)
        ) {
            categoryMenu.classList.remove('show');
        }
    });

    // Fermer avec Echap
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
            categoryMenu.classList.remove('show');
        }
    });
}
document.addEventListener("DOMContentLoaded", function () {

    const dropdown = document.querySelector(".user-dropdown");
    if (!dropdown) return;

    const toggle = dropdown.querySelector(".user-toggle");
    const menu = dropdown.querySelector(".user-menu");

    // toggle open/close
    toggle.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();

        menu.classList.toggle("show");
    });

    // clic dans le menu ne ferme pas
    menu.addEventListener("click", function (e) {
        e.stopPropagation();
    });

    // clic dehors → fermer
    document.addEventListener("click", function () {
        menu.classList.remove("show");
    });

    // ESC → fermer
    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
            menu.classList.remove("show");
        }
    });
});
  </script>

  {{ include('components/modal_auth.html.twig') }}
</body>
</html>





