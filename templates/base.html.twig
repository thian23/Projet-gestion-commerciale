<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin - SenBazar{% endblock %}</title>
    <link rel="icon" href="/assets/img/brand/logoN.jpeg">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        :root {
            --sidebar-width: 280px;
            --admin-theme: #10B981;
            --admin-accent: #F59E0B;
            --admin-dark: #1F2937;
            --bg-light: #F9FAFB;
        }

        body { background-color: var(--bg-light); font-family: 'Inter', sans-serif; overflow-x: hidden; }

        #sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            left: 0; top: 0;
            background: var(--admin-dark);
            color: white;
            transition: all 0.3s;
            z-index: 1000;
        }

        #sidebar.active { left: calc(-1 * var(--sidebar-width)); }

        .sidebar-header { padding: 25px; background: rgba(0,0,0,0.2); }

        #sidebar ul li a {
            padding: 15px 25px;
            display: block;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            transition: 0.3s;
            font-size: 0.95rem;
        }

        #sidebar ul li a:hover, #sidebar ul li a.active {
            color: white;
            background: rgba(255,255,255,0.05);
            border-left: 4px solid var(--admin-theme);
        }

        #content {
            width: calc(100% - var(--sidebar-width));
            margin-left: var(--sidebar-width);
            transition: all 0.3s;
            padding: 20px;
        }

        #content.active { width: 100%; margin-left: 0; }

        .navbar-admin { background: white; border-radius: 15px; margin-bottom: 25px; border: none; }

        @media (max-width: 992px) {
            #sidebar { left: calc(-1 * var(--sidebar-width)); }
            #sidebar.active { left: 0; }
            #content { width: 100%; margin-left: 0; }
        }
    </style>
</head>
<body>

    {# ON APPELLE LA SIDEBAR ICI #}
    {{ include('sidebar.html.twig') }}

    <div id="content">
        <nav class="navbar navbar-admin shadow-sm px-3 py-2">
            <button type="button" id="sidebarCollapse" class="btn btn-light rounded-circle">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="ms-auto d-flex align-items-center">
                <div class="text-end me-3 d-none d-sm-block">
                    <p class="m-0 small fw-bold">{{ app.user.prenom }}</p>
                    <p class="m-0 text-muted" style="font-size: 11px;">Administrateur</p>
                </div>
                <img src="https://ui-avatars.com/api/?name={{ app.user.prenom }}&background=10B981&color=fff" class="rounded-circle border" width="40">
            </div>
        </nav>

        {% block body %}{% endblock %}
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').toggleClass('active');
                $('#content').toggleClass('active');
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>



