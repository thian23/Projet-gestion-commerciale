{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<section class="min-vh-100 d-flex align-items-center py-5" style="background-color: #F6FBF7;">
    <div class="container">
        <div class="row justify-content-center">
            {# Un peu plus large que le login pour le confort des champs #}
            <div class="col-12 col-sm-11 col-md-8 col-lg-6 col-xl-4">
                
                <div class="card border-0 shadow-lg rounded-4">
                    <div class="card-body p-4 p-md-5">
                        
                        <h2 class="text-center fw-bold mb-4" style="color: #2E4A5B;">Creer un compte</h2>

                        <form method="post" action="{{ path('register') }}">
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted">Nom</label>
                                    <input type="text" name="nom" class="form-control border-0 bg-light shadow-sm" placeholder="Nom" required>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted">Prenom</label>
                                    <input type="text" name="prenom" class="form-control border-0 bg-light shadow-sm" placeholder="Prenom" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Telephone</label>
                                <input type="tel" name="telephone" class="form-control border-0 bg-light shadow-sm" placeholder="06..." required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Adresse</label>
                                <input type="text" name="adresse" class="form-control border-0 bg-light shadow-sm" placeholder="Votre adresse" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Email</label>
                                <input type="email" name="email" class="form-control border-0 bg-light shadow-sm" placeholder="email@exemple.com" required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted">Mot de passe</label>
                                <input type="password" name="password" class="form-control border-0 bg-light shadow-sm" placeholder="••••••••" required>
                            </div>

                            <button type="submit" class="btn btn-lg w-100 text-white fw-bold shadow-sm" 
                                    style="background-color: #10B981; border-radius: 10px; font-size: 1rem;">
                                S’inscrire
                            </button>
                        </form>

                        <div class="text-center mt-4 pt-3 border-top">
                            <p class="text-muted small mb-0">Deja un compte ? 
                                <a href="{{ path('login') }}" class="fw-bold text-decoration-none" style="color: #10B981;">
                                    Se connecter
                                </a>
                            </p>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
{% endblock %}




