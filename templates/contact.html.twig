{{ include('navbar.html.twig') }}

{% block title %}Contactez-nous | DeenShop{% endblock %}

{% block body %}
<div class="container py-5">
    
    <!-- HEADER DE LA PAGE -->
    <div class="text-center max-width-md mx-auto mb-5">
        <span class="badge bg-custom-light text-custom-color px-3 py-2 rounded-pill fw-bold text-uppercase mb-2" style="font-size: 12px; letter-spacing: 1px;">
            Un besoin ? Une question ?
        </span>
        <h1 class="fw-bold text-dark display-5" style="letter-spacing: -1px;">Contactez notre équipe</h1>
        <p class="text-muted lead">Nous vous répondons en général en moins de 24 heures. N'hésitez pas à nous écrire ou nous appeler directement.</p>
    </div>

    <div class="row g-4 justify-content-center">
        
        <!-- SECTION 1 : COORDONNÉES & INFOS -->
        <div class="col-12 col-lg-4">
            <div class="d-flex flex-column gap-3 h-100">
                
                <!-- Téléphone -->
                <div class="card border-0 shadow-sm rounded-4 p-4 contact-info-card">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-box bg-custom-light text-custom-color rounded-circle">
                            <i class="fa-solid fa-phone fs-5"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold text-dark mb-1">Téléphone & WhatsApp</h6>
                            <a href="tel:+221770000000" class="text-secondary text-decoration-none">+221 77 000 00 00</a>
                        </div>
                    </div>
                </div>

                <!-- Email -->
                <div class="card border-0 shadow-sm rounded-4 p-4 contact-info-card">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-box bg-success-subtle text-success rounded-circle">
                            <i class="fa-solid fa-envelope fs-5"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold text-dark mb-1">Adresse Email</h6>
                            <a href="mailto:contact@deenshop.com" class="text-secondary text-decoration-none">contact@deenshop.com</a>
                        </div>
                    </div>
                </div>

                <!-- Adresse physique -->
                <div class="card border-0 shadow-sm rounded-4 p-4 contact-info-card">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-box bg-info-subtle text-info rounded-circle">
                            <i class="fa-solid fa-location-dot fs-5"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold text-dark mb-1">Notre Boutique</h6>
                            <p class="text-secondary mb-0">Sacré-Cœur 3, VDN<br>Dakar, Sénégal</p>
                        </div>
                    </div>
                </div>

                <!-- Horaires d'ouverture -->
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-dark text-white h-100 d-flex flex-column justify-content-center">
                    <h6 class="fw-bold text-white mb-3"><i class="fa-regular fa-clock me-2 text-custom-color"></i>Heures d'ouverture</h6>
                    <ul class="list-unstyled mb-0 small opacity-75 d-flex flex-column gap-2">
                        <li class="d-flex justify-content-between"><span>Lundi - Vendredi :</span> <span class="fw-bold">09h00 - 19h00</span></li>
                        <li class="d-flex justify-content-between"><span>Samedi :</span> <span class="fw-bold">10h00 - 18h00</span></li>
                        <li class="d-flex justify-content-between"><span>Dimanche :</span> <span class="text-custom-color fw-bold">Fermé</span></li>
                    </ul>
                </div>

            </div>
        </div>

        <!-- SECTION 2 : FORMULAIRE DE CONTACT -->
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                <h3 class="fw-bold text-dark mb-2">Envoyez-nous un message</h3>
                <p class="text-muted small mb-4">Tous les champs marqués d'une astérisque (*) sont obligatoires.</p>

                {# Gestion des messages Flash de Symfony en cas de succès #}
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label === 'error' ? 'danger' : label }} alert-dismissible fade show rounded-3 mb-4" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                <form method="post" action="{{ path('app_contact_submit') }}" class="needs-validation" novalidate>
                    <div class="row g-3">
                        <!-- Nom Complet -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Nom complet *</label>
                            <input type="text" name="contact[name]" class="form-control border-0 bg-light rounded-3 px-3" placeholder="Ex: Fatou Diop" style="height: 46px;" required>
                        </div>

                        <!-- Email -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Adresse email *</label>
                            <input type="email" name="contact[email]" class="form-control border-0 bg-light rounded-3 px-3" placeholder="Ex: fatou@gmail.com" style="height: 46px;" required>
                        </div>

                        <!-- Téléphone (optionnel mais recommandé au Sénégal) -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Numéro de téléphone</label>
                            <input type="tel" name="contact[phone]" class="form-control border-0 bg-light rounded-3 px-3" placeholder="Ex: 77 123 45 67" style="height: 46px;">
                        </div>

                        <!-- Sujet -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Sujet du message *</label>
                            <select name="contact[subject]" class="form-select border-0 bg-light rounded-3 px-3" style="height: 46px;" required>
                                <option value="" disabled selected hidden>Choisissez un sujet...</option>
                                <option value="Service Client">Service Client & Suivi de commande</option>
                                <option value="Partenariat">Demande de partenariat</option>
                                <option value="Autre">Autre demande</option>
                            </select>
                        </div>

                        <!-- Message -->
                        <div class="col-12">
                            <label class="form-label small fw-bold text-secondary mb-1">Votre message *</label>
                            <textarea name="contact[message]" rows="5" class="form-control border-0 bg-light rounded-3 p-3" placeholder="Écrivez votre message ici..." required></textarea>
                        </div>

                        <!-- Bouton d'envoi -->
                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-custom-primary rounded-pill fw-bold px-5 py-2.5 text-uppercase" style="font-size: 14px; letter-spacing: 0.5px;">
                                <i class="fa-regular fa-paper-plane me-2"></i> Envoyer le message
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

<!-- LE STYLE PERSONNALISÉ (Identité Visuelle Graphique) -->
<style>
    /* Rappel de votre charte graphique harmonieuse */
    .text-custom-color { color: #EFB7C1 !important; }
    .bg-custom-light { background-color: #fdf3f3 !important; }
    .btn-custom-primary { background-color: #EFB7C1 !important; color: #ffffff !important; border: none; transition: all 0.3s ease; }
    .btn-custom-primary:hover { background-color: #a86266 !important; transform: translateY(-1px); }
    
    /* Inputs au focus */
    .form-control:focus, .form-select:focus { 
        background-color: #ffffff !important; 
        border: 1px solid #EFB7C1 !important; 
        box-shadow: 0 0 0 4px rgba(217, 124, 138, 0.12) !important; 
    }

    /* Boite d'icônes pour les coordonnées */
    .icon-box {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .bg-success-subtle { background-color: #e8f5e9 !important; }
    .text-success { color: #198754 !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info { color: #0284c7 !important; }

    .max-width-md { max-width: 650px; }

    .contact-info-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .contact-info-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
    }
</style>

<!-- Script Bootstrap de validation native des champs -->
<script>
(() => {
  'use strict'
  const forms = document.querySelectorAll('.needs-validation')
  Array.from(forms).forEach(form => {
    form.addEventListener('submit', event => {
      if (!form.checkValidity()) {
        event.preventDefault()
        event.stopPropagation()
      }
      form.classList.add('was-validated')
    }, false)
  })
})()
</script>
{% endblock %}