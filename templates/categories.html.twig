{% extends 'base.html.twig' %}

{% block title %}Categories | SenBazar Admin{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="row align-items-center g-3 mb-4">
        <div class="col-12 col-sm-auto">
            <h2 class="fw-bold m-0 text-dark" style="letter-spacing: -0.5px;">Gestion des categories</h2>
            <p class="text-muted small mb-0">Visualisez, creez et organisez vos categories de produits</p>
        </div>
        <div class="col-12 col-sm text-sm-end">
            <button class="btn rounded-pill px-4 fw-bold text-uppercase" data-bs-toggle="modal" data-bs-target="#categoryModal" style="font-size: 13px; height: 42px; letter-spacing: 0.5px; background-color:#10B981;color:white">
                <i class="fa-solid fa-plus me-2"></i>Ajouter une categorie
            </button>
        </div>
    </div>

    <!-- ZONE DE RECHERCHE -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row">
                <div class="col-12 col-md-5">
                    <div class="input-group">
                        <span class="input-group-text border-0 bg-light rounded-start-pill ps-3 text-secondary">
                            <i class="fa-solid fa-magnifying-glass opacity-50"></i>
                        </span>
                        <input type="text" id="searchCategory" class="form-control border-0 bg-light rounded-end-pill px-3" placeholder="Rechercher une categorie par son nom..." style="height: 42px; font-size: 14px;">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLEAU & RESULTATS -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive-custom">
                <table class="table align-middle mb-0" id="categoryTable">
                    <thead>
                        <tr class="text-secondary border-bottom bg-light">
                            <th class="ps-4 py-3" style="width: 15%;">ID</th>
                            <th class="py-3" style="width: 60%;">Nom de la categorie</th>
                            <th class="py-3 text-center pe-4" style="width: 25%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for c in categories %}
                            <tr class="category-row border-bottom-light" data-name="{{ c.nom|lower }}">
                                <td class="ps-4 fw-bold text-dark" data-label="ID">#{{ c.id }}</td>
                                <td data-label="Nom">
                                    <div class="fw-bold text-dark text-truncate-mobile" style="font-size: 15px;">{{ c.nom }}</div>
                                </td>
                                <td data-label="Actions" class="text-sm-center pe-sm-4">
                                    <div class="d-flex justify-content-start justify-content-sm-center align-items-center gap-2">
                                        <button type="button" class="btn btn-sm btn-action-edit rounded-pill px-3 fw-medium shadow-sm" onclick="openEditModal({{ c.id }}, '{{ c.nom|e('js') }}')" style="font-size: 12px; height: 32px;">
                                            <i class="fa-solid fa-pen-to-square me-1.5"></i>Modifier
                                        </button>
                                        <button type="button" class="btn btn-sm btn-light border rounded-pill px-3 fw-medium text-danger shadow-sm" onclick="openDeleteModal({{ c.id }})" style="font-size: 12px; height: 32px;">
                                            <i class="fa-solid fa-trash-can me-1.5"></i>Supprimer
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-folder-open fs-2 mb-3 opacity-20"></i>
                                    <p class="mb-0">Aucune categorie enregistree pour le moment.</p>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <!-- Message d'absence de resultats apres filtrage -->
            <div id="noResultsMessage" class="text-center py-5 text-muted d-none">
                <i class="fa-solid fa-magnifying-glass fs-2 mb-3 opacity-20"></i>
                <p class="mb-0 fw-medium">Aucune categorie ne correspond a votre recherche.</p>
            </div>
        </div>

        <!-- FOOTER PAGINATION -->
        <div class="card-footer bg-white border-0 py-4">
            <nav>
                <ul class="pagination justify-content-center mb-0 gap-1" id="pagination"></ul>
            </nav>
        </div>
    </div>
</div>

<!-- MODAL : AJOUT -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-bottom-light px-4">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-folder-plus me-2" style="color: #10B981;"></i>Ajouter une categorie</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="{{ path('app_category_create') }}">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary mb-1">Nom de la categorie</label>
                        <input type="text" name="category[nom]" class="form-control border-0 bg-light rounded-3 px-3" placeholder="Ex: Informatique, Mode, Beaute..." style="height: 44px;" required>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill fw-semibold px-4" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-custom-primary rounded-pill fw-bold px-4">Ajouter</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL : MODIFICATION -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-bottom-light px-4">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-pen-to-square me-2" style="color: #10B981;"></i>Modifier la categorie</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" id="editCategoryForm">
                <div class="modal-body p-4">
                    <input type="hidden" name="id" id="editCategoryId">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary mb-1">Nom revise</label>
                        <input type="text" name="nom" id="editCategoryName" class="form-control border-0 bg-light rounded-3 px-3" style="height: 44px;" required>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill fw-semibold px-4" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-custom-primary rounded-pill fw-bold px-4">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL : SUPPRESSION -->
<div class="modal fade" id="deleteCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 px-4 pt-4 pb-0 justify-content-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-danger-subtle text-danger" style="width: 56px; height: 56px;">
                    <i class="fa-solid fa-triangle-exclamation fs-4"></i>
                </div>
            </div>
            <form method="post" id="deleteCategoryForm">
                <div class="modal-body p-4 text-center">
                    <input type="hidden" name="id" id="deleteCategoryId">
                    <h5 class="fw-bold text-dark mb-2">Etes-vous sur ?</h5>
                    <p class="text-muted small mb-0">Cette action est irreversible. Les produits associes pourraient perdre leur liaison de categorie.</p>
                </div>
                <div class="modal-footer border-0 p-3 bg-light d-flex justify-content-stretch rounded-bottom-4 gap-2">
                    <button type="button" class="btn btn-white border rounded-pill fw-medium flex-grow-1" data-bs-dismiss="modal" style="font-size: 14px;">Annuler</button>
                    <button type="submit" class="btn btn-danger rounded-pill fw-bold flex-grow-1" style="font-size: 14px;">Supprimer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- INTERACTION & LOGIQUE JS COMPLETE -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('searchCategory');
    const tableRows = Array.from(document.querySelectorAll('.category-row'));
    const paginationContainer = document.getElementById('pagination');
    const noResultsMessage = document.getElementById('noResultsMessage');

    let currentPage = 1;
    const perPage = 5;
    let visibleRows = [...tableRows];

    function normalize(str) {
        return (str || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
    }

    function filterAndPaginate() {
        const search = normalize(searchInput.value);

        visibleRows = tableRows.filter(row => {
            const name = normalize(row.dataset.name);
            return !search || name.includes(search);
        });

        if (visibleRows.length === 0 && tableRows.length > 0) {
            noResultsMessage.classList.remove('d-none');
            paginationContainer.innerHTML = '';
            tableRows.forEach(r => r.style.display = 'none');
            return;
        } else {
            noResultsMessage.classList.add('d-none');
        }

        const totalPages = Math.ceil(visibleRows.length / perPage);
        if (currentPage > totalPages) currentPage = totalPages || 1;

        const startIdx = (currentPage - 1) * perPage;
        const endIdx = startIdx + perPage;

        tableRows.forEach(row => row.style.display = 'none');
        visibleRows.slice(startIdx, endIdx).forEach(row => row.style.display = '');

        renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
        paginationContainer.innerHTML = '';
        if (totalPages <= 1) return;

        createPageButton('«', currentPage > 1, () => { currentPage--; filterAndPaginate(); });

        for (let i = 1; i <= totalPages; i++) {
            createPageButton(i, true, () => { currentPage = i; filterAndPaginate(); }, i === currentPage);
        }

        createPageButton('»', currentPage < totalPages, () => { currentPage++; filterAndPaginate(); });
    }

    function createPageButton(text, enabled, onClick, isActive = false) {
        const li = document.createElement('li');
        li.className = `page-item ${!enabled ? 'disabled' : ''} ${isActive ? 'active' : ''}`;
        
        const a = document.createElement('a');
        a.className = `page-link border-0 mx-0.5 rounded-3 px-3 py-2 fw-semibold ${isActive ? 'btn-active-page text-white' : 'bg-light text-dark'}`;
        a.href = '#';
        a.textContent = text;
        
        if (enabled) {
            a.addEventListener('click', (e) => {
                e.preventDefault();
                onClick();
            });
        }
        li.appendChild(a);
        paginationContainer.appendChild(li);
    }

    searchInput.addEventListener('input', () => {
        currentPage = 1;
        filterAndPaginate();
    });

    filterAndPaginate();
});

function openEditModal(id, name) {
    document.getElementById('editCategoryId').value = id;
    document.getElementById('editCategoryName').value = name;
    document.getElementById('editCategoryForm').action = '/category/edit/' + id;

    const modal = new bootstrap.Modal(document.getElementById('editCategoryModal'));
    modal.show();
}

function openDeleteModal(id) {
    document.getElementById('deleteCategoryId').value = id;
    document.getElementById('deleteCategoryForm').action = '/category/delete/' + id;

    const modal = new bootstrap.Modal(document.getElementById('deleteCategoryModal'));
    modal.show();
}
</script>

<style>
    /* UTILITAIRES THEME : #10B981 */
    .btn-custom-primary {
        background-color: #10B981 !important;
        color: #ffffff !important;
        border: none;
    }
    .btn-custom-primary:hover {
        background-color: #15803D !important;
    }
    .btn-action-edit {
        background-color: #F6FBF7 !important;
        color: #10B981 !important;
        border: 1px solid #DDEFE3 !important;
    }
    .btn-action-edit:hover {
        background-color: #10B981 !important;
        color: #ffffff !important;
    }
    .btn-active-page {
        background-color: #10B981 !important;
    }
    .form-control:focus { 
        background-color: #ffffff !important; 
        border: 1px solid #10B981 !important; 
        box-shadow: 0 0 0 3px rgba(217, 124, 138, 0.12) !important; 
    }

    /* STRUCTURE DE COMPOSANTS GENERALE */
    .card { border: none !important; }
    .border-bottom-light { border-bottom: 1px solid #f1f5f9; }
    .btn-light { background-color: #f8fafc; border-color: #e2e8f0 !important; }
    .btn-light:hover { background-color: #f1f5f9; }
    .bg-danger-subtle { background-color: #fee2e2 !important; }

    /* STRUCTURE RESPONSIVE MOBILE FIRST */
    @media (max-width: 575.98px) {
        .table-responsive-custom table, 
        .table-responsive-custom thead, 
        .table-responsive-custom tbody, 
        .table-responsive-custom th, 
        .table-responsive-custom td, 
        .table-responsive-custom tr { 
            display: block; 
        }
        .table-responsive-custom thead { display: none; }
        .table-responsive-custom tr {
            padding: 1.25rem 1rem;
            margin: 1rem;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
        }
        .table-responsive-custom td {
            text-align: right;
            padding: 0.6rem 0 !important;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: none !important;
        }
        .table-responsive-custom td::before {
            content: attr(data-label);
            font-weight: 700;
            text-transform: uppercase;
            font-size: 11px;
            color: #64748b;
        }
        .table-responsive-custom td.ps-4 { padding-left: 0 !important; }
        .text-truncate-mobile { max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    }
</style>
{% endblock %}


