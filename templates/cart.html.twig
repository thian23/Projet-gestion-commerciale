  <!--==============================
    Styles Specifiques au Panier
  ============================== -->
  <style>
    /* Structure Grille Panier pour PC */
    @media (min-width: 768px) {
        .deen-cart-heading {
            display: grid !important;
            grid-template-columns: 5fr 3fr 2fr 1fr;
            align-items: center;
        }
    }

    /* Style des Cartes d'articles */
    .cart-item-row {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid #f0f0f0 !important;
    }
    .cart-item-row:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(0,0,0,0.05) !important;
    }

    /* Boutons Quantite Modernises */
    .qty-btn-group .btn {
        border-color: #dee2e6;
        background-color: #fff;
        color: #495057;
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        transition: all 0.2s ease;
    }
    .qty-btn-group .btn:hover {
        background-color: var(--theme-color);
        border-color: var(--theme-color);
        color: #fff;
    }
    .qty-count {
        min-width: 35px;
        display: inline-block;
    }

    /* Design des Cartes de Lots */
    .lot-card {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 10px 14px;
        cursor: pointer;
        background-color: #fff;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        min-width: 110px;
        text-align: center;
        position: relative;
    }
    .lot-card:hover {
        border-color: #ced4da;
        transform: scale(1.02);
    }
    .lot-card.active {
        border-color: var(--theme-color) !important;
        background-color: rgba(181, 124, 124, 0.04); /* Teinte tres legere basee sur votre couleur principale */
        color: #000;
    }
    .lot-card.active::after {
        content: '✓';
        position: absolute;
        top: -8px;
        right: -8px;
        width: 18px;
        height: 18px;
        background-color: var(--theme-color);
        color: #fff;
        border-radius: 50%;
        font-size: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    /* Liens et Actions */
    .deen-cart-back {
        color: #495057;
    }
    .deen-cart-back:hover {
        color: var(--theme-color);
    }
    .deen-checkout-btn {
        background-color: var(--theme-color);
        border-radius: 12px;
        letter-spacing: 0.5px;
    }
    .deen-checkout-btn:hover {
        background-color: #9e6464; /* Assombrissement leger pour l'effet survol */
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(181, 124, 124, 0.3) !important;
    }
    
    .transition-all {
        transition: all 0.25s ease-in-out;
    }
  </style>

