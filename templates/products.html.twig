{% extends 'base.html.twig' %}

{% block title %}Produits | SenBazar Admin{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="row align-items-center g-3 mb-4">
        <div class="col-12 col-sm-auto">
            <h2 class="fw-bold m-0 text-dark" style="letter-spacing: -0.5px;">Gestion des produits</h2>
            <p class="text-muted small mb-0">Visualisez, filtrez et mettez a jour votre inventaire de produits</p>
        </div>
        <div class="col-12 col-sm text-sm-end">
            <button class="btn btn-dark rounded-pill px-4 fw-bold text-uppercase" data-bs-toggle="modal" data-bs-target="#productModal" style="font-size: 13px; height: 42px; letter-spacing: 0.5px;">
                <i class="fa-solid fa-plus me-2"></i>Creer un produit
            </button>
        </div>
    </div>

    <!-- 🔎 ZONE DE RECHERCHE & FILTRES -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row g-2">
                <!-- SEARCH -->
                <div class="col-12 col-md-4">
                    <div class="input-group">
                        <span class="input-group-text border-0 bg-light rounded-start-pill ps-3 text-secondary">
                            <i class="fa-solid fa-magnifying-glass opacity-50"></i>
                        </span>
                        <input type="text" id="searchProduct" class="form-control border-0 bg-light rounded-end-pill px-3" placeholder="Rechercher produit..." style="height: 42px; font-size: 14px;">
                    </div>
                </div>

                <!-- CATEGORY -->
                <div class="col-12 col-sm-4 col-md-3">
                    <select id="filterCategory" class="form-select border-0 bg-light rounded-pill px-3" style="height: 42px; font-size: 14px;">
                        <option value="">Toutes les categories</option>
                        {% set categoriesList = [] %}
                        {% for p in products %}
                            {% if p.category and p.category.nom not in categoriesList %}
                                {% set categoriesList = categoriesList|merge([p.category.nom]) %}
                                <option value="{{ p.category.nom }}">{{ p.category.nom }}</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </div>

                <!-- STOCK -->
                <div class="col-12 col-sm-4 col-md-2">
                    <select id="filterStock" class="form-select border-0 bg-light rounded-pill px-3" style="height: 42px; font-size: 14px;">
                        <option value="">Stock (Tous)</option>
                        <option value="ok">Disponible</option>
                        <option value="out">Rupture</option>
                    </select>
                </div>

                <!-- TAGS -->
                <div class="col-12 col-sm-4 col-md-3">
                    <select id="filterPromo" class="form-select border-0 bg-light rounded-pill px-3" style="height: 42px; font-size: 14px;">
                        <option value="">Tags (Tous)</option>
                        <option value="promo">Promotion</option>
                        <option value="new">Nouveaute</option>
                        <option value="best">Best seller</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLEAU & RESULTATS -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive-custom">
                <table class="table align-middle mb-0" id="productTable">
                    <thead>
                        <tr class="text-secondary border-bottom bg-light">
                            <th class="ps-4 py-3" style="width: 35%;">Produit</th>
                            <th class="py-3" style="width: 15%;">Prix</th>
                            <th class="py-3" style="width: 15%;">Stock</th>
                            <th class="py-3" style="width: 15%;">Categorie</th>
                            <th class="py-3" style="width: 10%;">Tags</th>
                            <th class="py-3 text-center pe-4" style="width: 10%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for p in products %}
                            <tr class="product-row border-bottom-light"
                                data-name="{{ p.titre|lower }}"
                                data-category="{{ p.category ? p.category.nom|lower : '' }}"
                                data-stock="{{ p.stock > 0 ? 'ok' : 'out' }}"
                                data-promo="
                                    {% if p.promotion %}promo {% endif %}
                                    {% if p.nouveaute %}new {% endif %}
                                    {% if p.bestSeller %}best{% endif %}
                                ">

                                <!-- PRODUIT -->
                                <td class="ps-4" data-label="Produit">
                                    <div class="d-flex align-items-center gap-3 text-start grid-mobile-align">
                                        <img src="{{ asset('uploads/products/' ~ p.image) }}" alt="{{ p.titre }}" class="rounded-3 shadow-sm border" style="width:50px; height:50px; object-fit:cover;">
                                        <div class="text-truncate-mobile">
                                            <div class="fw-bold text-dark" style="font-size: 15px;">{{ p.titre }}</div>
                                            <small class="text-muted d-block text-truncate" style="max-width: 220px;">{{ p.description|slice(0, 40) }}...</small>
                                        </div>
                                    </div>
                                </td>

                                <!-- PRIX -->
                                <td data-label="Prix" class="fw-bold text-custom-color" style="font-size: 15px;">
                                    {{ p.prix|number_format(0, ',', ' ') }} FCFA
                                </td>

                                <!-- STOCK -->
                                <td data-label="Stock">
                                    {% if p.stock > 0 %}
                                        <span class="badge rounded-pill bg-success-subtle text-success px-3 py-1.5" style="font-weight: 600; font-size: 12px;">
                                            Disponible ({{ p.stock }})
                                        </span>
                                    {% else %}
                                        <span class="badge rounded-pill bg-danger-subtle text-danger px-3 py-1.5" style="font-weight: 600; font-size: 12px;">
                                            Rupture
                                        </span>
                                    {% endif %}
                                </td>

                                <!-- CATEGORIE -->
                                <td data-label="Categorie" class="text-secondary fw-medium">
                                    {{ p.category ? p.category.nom : '---' }}
                                </td>

                                <!-- TAGS -->
                                <td data-label="Tags">
                                    <div class="d-flex flex-wrap gap-1 justify-content-end justify-content-sm-start">
                                        {% if p.promotion %}
                                            <span class="badge bg-warning text-dark rounded-3 px-2 py-1" style="font-size: 11px;">Promo</span>
                                        {% endif %}
                                        {% if p.nouveaute %}
                                            <span class="badge bg-info text-white rounded-3 px-2 py-1" style="font-size: 11px;">New</span>
                                        {% endif %}
                                        {% if p.bestSeller %}
                                            <span class="badge bg-dark text-white rounded-3 px-2 py-1" style="font-size: 11px;">Best</span>
                                        {% endif %}
                                        {% if p.phares %}
                                            <span class="badge bg-secondary text-white rounded-3 px-2 py-1" style="font-size: 11px;">Phare</span>
                                        {% endif %}
                                    </div>
                                </td>

                                <!-- ACTIONS -->
                                <td data-label="Actions" class="text-sm-center pe-sm-4">
                                    <div class="d-flex justify-content-end justify-content-sm-center align-items-center gap-1.5">
                                        <button class="btn btn-icon-action btn-edit" data-bs-toggle="modal" data-bs-target="#edit{{ p.id }}" title="Modifier">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <button class="btn btn-icon-action btn-lots" data-bs-toggle="modal" data-bs-target="#lotsModal{{ p.id }}" title="Gerer les lots">
                                            <i class="fa-solid fa-boxes-stacked"></i>
                                        </button>
                                        <!-- MODIFIE ICI : Remplacement par un bouton declencheur de modal de confirmation globale -->
                                        <button type="button" class="btn btn-icon-action btn-delete" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal" data-url="{{ path('app_product_delete', {id: p.id}) }}" data-title="{{ p.titre }}" title="Supprimer">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-box-open fs-2 mb-3 opacity-20"></i>
                                    <p class="mb-0">Aucun produit enregistre pour le moment.</p>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <!-- Message de filtrage vide -->
            <div id="noResultsMessage" class="text-center py-5 text-muted d-none">
                <i class="fa-solid fa-magnifying-glass fs-2 mb-3 opacity-20"></i>
                <p class="mb-0 fw-medium">Aucun produit ne correspond a vos criteres de recherche.</p>
            </div>
        </div>

        <!-- FOOTER PAGINATION -->
        <div class="card-footer bg-white border-0 py-4">
            <nav>
                <ul class="pagination justify-content-center mb-0 gap-1" id="pagination"></ul>
            </nav>
        </div>
    </div>
</div>

<!-- MODAL : MODIFICATION -->
{% for p in products %}
<div class="modal fade" id="edit{{ p.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <form method="post" action="{{ path('app_product_edit', {id: p.id}) }}" enctype="multipart/form-data" class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-bottom-light px-4">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-pen-to-square me-2 text-custom-color"></i>Modifier : {{ p.titre }}</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-12 text-center mb-2">
                        {% if p.image %}
                            <img src="{{ asset('uploads/products/' ~ p.image) }}" class="rounded-3 border shadow-sm" style="max-height:140px; object-fit: cover;">
                        {% endif %}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-secondary mb-1">Nom du produit</label>
                        <input name="product[titre]" value="{{ p.titre }}" class="form-control border-0 bg-light rounded-3 px-3" style="height: 44px;" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-secondary mb-1">Prix (FCFA)</label>
                        <input name="product[prix]" value="{{ p.prix }}" class="form-control border-0 bg-light rounded-3 px-3" style="height: 44px;" required>
                    </div>

                    <div class="col-12">
                        <label class="form-label small fw-bold text-secondary mb-1">Description</label>
                        <textarea name="product[description]" class="form-control border-0 bg-light rounded-3 p-3" rows="3">{{ p.description }}</textarea>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-secondary mb-1">Quantite en stock</label>
                        <input name="product[stock]" value="{{ p.stock }}" class="form-control border-0 bg-light rounded-3 px-3" style="height: 44px;" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-secondary mb-1">Remplacer la photo</label>
                        <input type="file" name="product[imageFile]" class="form-control border-0 bg-light rounded-3" style="padding-top: 9px; height: 44px;">
                    </div>

                    <div class="col-12 mt-3 bg-light p-3 rounded-4 border">
                        <div class="row text-center g-2">
                            <div class="col-6 col-md-3">
                                <label class="small fw-bold d-block mb-1 text-muted">Promotion</label>
                                <input type="checkbox" name="product[promotion]" class="form-check-input form-check-custom" {{ p.promotion ? 'checked' : '' }}>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="small fw-bold d-block mb-1 text-muted">Nouveaute</label>
                                <input type="checkbox" name="product[nouveaute]" class="form-check-input form-check-custom" {{ p.nouveaute ? 'checked' : '' }}>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="small fw-bold d-block mb-1 text-muted">Best Seller</label>
                                <input type="checkbox" name="product[bestSeller]" class="form-check-input form-check-custom" {{ p.bestSeller ? 'checked' : '' }}>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="small fw-bold d-block mb-1 text-muted">Phare</label>
                                <input type="checkbox" name="product[phares]" class="form-check-input form-check-custom" {{ p.phares ? 'checked' : '' }}>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0 px-4 pb-4 pt-0">
                <button type="button" class="btn btn-light rounded-pill fw-semibold px-4" data-bs-dismiss="modal">Annuler</button>
                <button type="submit" class="btn btn-custom-primary rounded-pill fw-bold px-4">Enregistrer</button>
            </div>
        </form>
    </div>
</div>
{% endfor %}

<!-- MODAL : GESTION DES LOTS -->
{% for p in products %}
<div class="modal fade" id="lotsModal{{ p.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <form method="post" action="{{ path('app_product_update_lots', {id: p.id}) }}" class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-bottom-light px-4">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-boxes-stacked text-success me-2"></i>Lots de : {{ p.titre }}</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4" id="lots-container-{{ p.id }}">
                {% for lot in p.lots %}
                <div class="row g-2 mb-2 lot-row align-items-center bg-light p-2 rounded-3 border mx-0">
                    <div class="col-12 col-md-4">
                        <input type="text" name="lots[{{ loop.index0 }}][nom]" value="{{ lot.nom }}" class="form-control border-0 bg-white" placeholder="Nom du lot" required>
                    </div>
                    <div class="col-6 col-md-3">
                        <input type="number" name="lots[{{ loop.index0 }}][quantite]" value="{{ lot.quantite }}" class="form-control border-0 bg-white" placeholder="Quantite" required>
                    </div>
                    <div class="col-6 col-md-3">
                        <input type="number" name="lots[{{ loop.index0 }}][prix]" value="{{ lot.prix }}" class="form-control border-0 bg-white" placeholder="Prix" required>
                    </div>
                    <div class="col-12 col-md-2 text-end">
                        <button type="button" class="btn btn-light text-danger border rounded-pill w-100" onclick="this.closest('.lot-row').remove()">
                            <i class="fa-solid fa-trash-can me-1"></i> <span class="d-md-none">Supprimer</span>
                        </button>
                    </div>
                </div>
                {% endfor %}
            </div>

            <div class="modal-footer border-0 p-4 pt-0 d-flex justify-content-between">
                <button type="button" class="btn btn-outline-success rounded-pill fw-semibold px-4" onclick="addLot({{ p.id }})">
                    <i class="fa-solid fa-plus me-1"></i> Ajouter un lot
                </button>
                <div>
                    <button type="button" class="btn btn-light rounded-pill fw-semibold px-4" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-success rounded-pill fw-bold px-4">Enregistrer</button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endfor %}

<!-- MODAL : CREATION -->
<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-bottom-light px-4">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-circle-plus me-2 text-custom-color"></i>Nouveau Produit</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="{{ path('app_product_create') }}" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Nom du produit</label>
                            <input name="product[titre]" class="form-control border-0 bg-light rounded-3 px-3" placeholder="Ex: Robe en soie" style="height: 44px;" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Categorie</label>
                            <select name="product[category]" class="form-select border-0 bg-light rounded-3 px-3" style="height: 44px;">
                                {% for c in categories %}
                                    <option value="{{ c.id }}">{{ c.nom }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label small fw-bold text-secondary mb-1">Description</label>
                            <textarea name="product[description]" rows="3" class="form-control border-0 bg-light rounded-3 p-3" placeholder="Details du produit..."></textarea>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Prix (FCFA)</label>
                            <input name="product[prix]" class="form-control border-0 bg-light rounded-3 px-3" placeholder="Prix en FCFA" style="height: 44px;">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary mb-1">Stock Initial</label>
                            <input name="product[stock]" class="form-control border-0 bg-light rounded-3 px-3" placeholder="Quantite" style="height: 44px;">
                        </div>

                        <div class="col-12">
                            <label class="form-label small fw-bold text-secondary mb-1">Photo du produit</label>
                            <input type="file" name="product[imageFile]" class="form-control border-0 bg-light rounded-3" style="padding-top: 9px; height: 44px;">
                        </div>

                        <div class="col-12 mt-3 bg-light p-3 rounded-4 border">
                            <div class="row text-center g-2">
                                <div class="col-6 col-md-3">
                                    <label class="small fw-bold d-block mb-1 text-muted">Promotion</label>
                                    <input type="checkbox" name="product[promotion]" class="form-check-input form-check-custom">
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="small fw-bold d-block mb-1 text-muted">Nouveaute</label>
                                    <input type="checkbox" name="product[nouveaute]" class="form-check-input form-check-custom">
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="small fw-bold d-block mb-1 text-muted">Best Seller</label>
                                    <input type="checkbox" name="product[bestSeller]" class="form-check-input form-check-custom">
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="small fw-bold d-block mb-1 text-muted">Phare</label>
                                    <input type="checkbox" name="product[phares]" class="form-check-input form-check-custom">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 px-4 pb-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill fw-semibold px-4" data-bs-dismiss="modal">Fermer</button>
                    <button type="submit" class="btn btn-custom-primary rounded-pill fw-bold px-5">Confirmer la creation</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- NOUVEAU MODAL GLOBAL : CONFIRMATION DE SUPPRESSION (ELEGANT & COHERENT) -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-body text-center p-4">
                <div class="text-danger mb-3">
                    <i class="fa-solid fa-circle-exclamation fs-1"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Supprimer le produit ?</h5>
                <p class="text-muted small mb-0">Etes-vous sur de vouloir supprimer definitivement <span id="deleteProductTitle" class="fw-bold text-dark"></span> ? Cette action est irreversible.</p>
            </div>
            <div class="modal-footer border-0 d-flex justify-content-center gap-2 pb-4 pt-0">
                <button type="button" class="btn btn-light rounded-pill fw-semibold px-4" data-bs-dismiss="modal">Annuler</button>
                <a id="deleteConfirmBtn" href="#" class="btn btn-danger rounded-pill fw-bold px-4">Supprimer</a>
            </div>
        </div>
    </div>
</div>

<!-- LOGIQUE JAVASCRIPT FILTRAGE & DYNAMISME -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const search = document.getElementById('searchProduct');
    const category = document.getElementById('filterCategory');
    const stock = document.getElementById('filterStock');
    const promo = document.getElementById('filterPromo');

    const rows = Array.from(document.querySelectorAll('.product-row'));
    const pagination = document.getElementById('pagination');
    const noResultsMessage = document.getElementById('noResultsMessage');

    let currentPage = 1;
    const perPage = 10;

    function normalize(str) {
        return (str || '').toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
    }

    function getFilteredRows() {
        const s = normalize(search.value);
        const cat = category.value.toLowerCase();
        const st = stock.value;
        const pr = promo.value;

        return rows.filter(row => {
            if (s && !normalize(row.dataset.name).includes(s)) return false;
            if (cat && row.dataset.category !== cat) return false;
            if (st && row.dataset.stock !== st) return false;
            if (pr && !row.dataset.promo.includes(pr)) return false;
            return true;
        });
    }

    function renderTable() {
        const filtered = getFilteredRows();

        if (filtered.length === 0 && rows.length > 0) {
            noResultsMessage.classList.remove('d-none');
            pagination.innerHTML = '';
            rows.forEach(r => r.style.display = 'none');
            return;
        } else {
            noResultsMessage.classList.add('d-none');
        }

        const start = (currentPage - 1) * perPage;
        const end = start + perPage;

        rows.forEach(r => r.style.display = 'none');
        filtered.slice(start, end).forEach(r => r.style.display = '');

        renderPagination(filtered.length);
    }

    function renderPagination(total) {
        pagination.innerHTML = '';
        const pages = Math.ceil(total / perPage);
        if (pages <= 1) return;

        for (let i = 1; i <= pages; i++) {
            const li = document.createElement('li');
            li.className = `page-item ${i === currentPage ? 'active' : ''}`;
            
            const a = document.createElement('a');
            a.className = `page-link border-0 mx-0.5 rounded-3 px-3 py-2 fw-semibold ${i === currentPage ? 'btn-active-page text-white' : 'bg-light text-dark'}`;
            a.href = '#';
            a.textContent = i;

            a.addEventListener('click', (e) => {
                e.preventDefault();
                currentPage = i;
                renderTable();
            });

            li.appendChild(a);
            pagination.appendChild(li);
        }
    }

    function reset() {
        currentPage = 1;
        renderTable();
    }

    search.addEventListener('input', reset);
    category.addEventListener('change', reset);
    stock.addEventListener('change', reset);
    promo.addEventListener('change', reset);

    renderTable();

    // SCRIPT DE GESTION DU MODAL DE SUPPRESSION DYNAMIQUE
    const confirmDeleteModal = document.getElementById('confirmDeleteModal');
    if (confirmDeleteModal) {
        confirmDeleteModal.addEventListener('show.bs.modal', (event) => {
            const button = event.relatedTarget; // Le bouton clique
            const deleteUrl = button.getAttribute('data-url'); 
            const productTitle = button.getAttribute('data-title'); 

            // Injection des valeurs dans le modal
            document.getElementById('deleteProductTitle').textContent = productTitle;
            document.getElementById('deleteConfirmBtn').setAttribute('href', deleteUrl);
        });
    }
});

function addLot(productId) {
    const container = document.getElementById('lots-container-' + productId);
    if (!container) return;

    const index = container.querySelectorAll('.lot-row').length;

    const row = document.createElement('div');
    row.className = 'row g-2 mb-2 lot-row align-items-center bg-light p-2 rounded-3 border mx-0';

    row.innerHTML = `
        <div class="col-12 col-md-4">
            <input type="text" name="lots[${index}][nom]" class="form-control border-0 bg-white" placeholder="Nom du lot (ex: Lot 4)" required>
        </div>
        <div class="col-6 col-md-3">
            <input type="number" name="lots[${index}][quantite]" class="form-control border-0 bg-white" placeholder="Quantite" min="1" required>
        </div>
        <div class="col-6 col-md-3">
            <input type="number" name="lots[${index}][prix]" class="form-control border-0 bg-white" placeholder="Prix" min="0" step="0.01" required>
        </div>
        <div class="col-12 col-md-2 text-end">
            <button type="button" class="btn btn-light text-danger border rounded-pill w-100" onclick="removeLotRow(this)">
                <i class="fa-solid fa-trash-can me-1"></i> <span class="d-md-none">Supprimer</span>
            </button>
        </div>
    `;
    container.appendChild(row);
    reindexLots(container);
}

function removeLotRow(button) {
    const row = button.closest('.lot-row');
    if (!row) return;
    const container = row.parentElement;
    row.remove();
    reindexLots(container);
}

function reindexLots(container) {
    const rows = container.querySelectorAll('.lot-row');
    rows.forEach((row, index) => {
        const inputs = row.querySelectorAll('input');
        inputs.forEach(input => {
            if (input.name.includes('[nom]')) input.name = `lots[${index}][nom]`;
            if (input.name.includes('[quantite]')) input.name = `lots[${index}][quantite]`;
            if (input.name.includes('[prix]')) input.name = `lots[${index}][prix]`;
        });
    });
}
</script>

