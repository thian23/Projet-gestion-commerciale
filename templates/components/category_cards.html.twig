<section class="categories-layout1 space" style="background: #f8f9fa; padding: 60px 0;">
  <div class="container">

    <!-- TITLE -->
    <div class="title-area text-center mb-5">
      <h2 class="sec-title fw-bold mb-3" style="color: #2c3e50; font-size: 2.5rem;">
        Nos Categories
      </h2>
      <div class="mt-3 mx-auto" style="width: 80px; height: 4px; background: var(--theme-color); border-radius: 2px;"></div>
    </div>

    <!-- CAROUSEL -->
    <div class="slider-container">
      <div class="slider-track">

        {% set categoryItems = categories|default([]) %}
        {% for category in categoryItems|merge(categoryItems) %}

          {% set icons = {
            'Vetements': 'fa-shirt',
            'Chaussures': 'fa-shoe-prints',
            'Accessoires de mode': 'fa-gem',
            'Beaute': 'fa-spray-can-sparkles',
            'Informatique': 'fa-laptop',
            'Maison': 'fa-house',
            'Electronique': 'fa-mobile-screen-button',
            'Sport et Fitness': 'fa-dumbbell',
            'Complements alimentaires': 'fa-prescription-bottle-medical'
          } %}

          {% set icon = icons[category.nom] ?? 'fa-box' %}

          <div class="category-card-wrapper">
            <div class="card h-100 border-0 shadow-sm text-center p-4"
                 style="border-radius: 15px;">

              <div class="cat-icon mb-3 d-flex align-items-center justify-content-center"
                   style="height: 80px; color: #F59E0B;">

                <i class="fa-solid {{ icon }} fa-3x"></i>

              </div>

              <h5 class="fw-semibold mt-auto" style="color:#333;">
                {{ category.nom }}
              </h5>

              <a href="{{ path('app_shop', { 'cat': category.id }) }}"
                 class="stretched-link"></a>

            </div>
          </div>

        {% endfor %}

      </div>
    </div>

  </div>
</section>
