<section class="min-vh-100 d-flex align-items-center bg-light py-5 mt-5 mt-sm-4 mt-md-0">
    <div class="container py-3">
        <div class="row justify-content-center px-2">
            
            <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5 col-xxl-4">
                
                <div class="card border-0 shadow-lg rounded-4">
                    <div class="card-body p-3 p-sm-5">
                        
                        <div class="text-center mb-4">
                            <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mx-auto mb-3" style="width: 60px; height: 60px;">
                                <i class="fal fa-user-lock fs-4"></i>
                            </div>
                            <h1 class="h3 fw-bold text-dark m-0">{{ title }}</h1>
                            <p class="text-muted small mt-1 mb-0">Bienvenue chez SenBazar</p>
                        </div>

                        {% if error is defined and error %}
                            <div class="alert alert-danger border-0 rounded-3 small d-flex align-items-center p-3 mb-4" role="alert">
                                <i class="fas fa-exclamation-circle me-2 fs-5 flex-shrink-0"></i>
                                <div>{{ error }}</div>
                            </div>
                        {% endif %}

                        <form method="post" action="{{ action }}">
                            
                            {% if register is defined and register %}
                                <div class="row g-3 mb-3">
                                    <div class="col-12 col-sm-6">
                                        <label class="form-label fw-medium text-secondary small mb-1">Nom</label>
                                        <input type="text" name="nom" class="form-control form-control-lg fs-6 rounded-3" placeholder="Nom" required>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <label class="form-label fw-medium text-secondary small mb-1">Prenom</label>
                                        <input type="text" name="prenom" class="form-control form-control-lg fs-6 rounded-3" placeholder="Prenom" required>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-medium text-secondary small mb-1">Telephone</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0 text-muted px-3 rounded-start-3"><i class="fal fa-phone"></i></span>
                                        <input type="tel" name="telephone" class="form-control form-control-lg fs-6 border-start-0 rounded-end-3" placeholder="77 000 00 00" required>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-medium text-secondary small mb-1">Adresse</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0 text-muted px-3 rounded-start-3"><i class="fal fa-map-marker-alt"></i></span>
                                        <input type="text" name="adresse" class="form-control form-control-lg fs-6 border-start-0 rounded-end-3" placeholder="Votre adresse complete" required>
                                    </div>
                                </div>
                            {% endif %}

                            <div class="mb-3">
                                <label class="form-label fw-medium text-secondary small mb-1">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted px-3 rounded-start-3"><i class="fal fa-envelope"></i></span>
                                    <input type="email" name="email" class="form-control form-control-lg fs-6 border-start-0 rounded-end-3" placeholder="nom@exemple.com" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-medium text-secondary small mb-1">Mot de passe</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted px-3 rounded-start-3"><i class="fal fa-lock"></i></span>
                                    <input type="password" name="password" class="form-control form-control-lg fs-6 border-start-0 rounded-end-3" placeholder="••••••••" required>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold py-3 shadow-sm rounded-3 fs-6">
                                {{ button }}
                            </button>
                        </form>

                        <div class="text-center mt-4">
                            {% if register is defined and register %}
                                <p class="text-muted small mb-0">Deja inscrit ? 
                                    <a href="{{ path('login_form') }}" class="fw-bold text-primary text-decoration-none hover-underline">Se connecter</a>
                                </p>
                            {% else %}
                                <p class="text-muted small mb-0">Nouveau client ? 
                                    <a href="{{ path('register_form') }}" class="fw-bold text-primary text-decoration-none hover-underline">Creer un compte</a>
                                </p>
                            {% endif %}
                        </div>

                        <div class="text-center mt-4 pt-3 border-top border-light-subtle">
                            <a href="/" class="text-secondary small text-decoration-none d-inline-flex align-items-center toggle-link">
                                <i class="fal fa-arrow-left me-2"></i>Retour a la boutique
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</section>



